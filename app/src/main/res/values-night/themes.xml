<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.HeadphoneTracker" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:statusBarColor">@color/background_dark</item>
        <item name="android:navigationBarColor">@color/nav_background</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="materialAlertDialogTheme">@style/AlertDialogTheme</item>
    </style>

    <!-- Alert Dialog Theme — Dark (hardcoded dark values) -->
    <style name="AlertDialogTheme" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="colorSurface">#1A2028</item>
        <item name="colorOnSurface">#F8FAFC</item>
        <item name="colorOnSurfaceVariant">#94A3B8</item>
        <item name="colorPrimary">#818CF8</item>
        <item name="colorError">#EF4444</item>
        <item name="materialAlertDialogTitleTextStyle">@style/AlertDialogTitleStyle</item>
        <item name="materialAlertDialogBodyTextStyle">@style/AlertDialogBodyStyle</item>
    </style>

    <style name="AlertDialogTheme_Dark" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorSurface">#1A2028</item>
        <item name="colorOnSurface">#F8FAFC</item>
        <item name="colorOnSurfaceVariant">#94A3B8</item>
        <item name="colorPrimary">#818CF8</item>
        <item name="colorError">#EF4444</item>
        <item name="materialAlertDialogTitleTextStyle">@style/AlertDialogTitleStyle</item>
        <item name="materialAlertDialogBodyTextStyle">@style/AlertDialogBodyStyle</item>
    </style>

    <style name="AlertDialogTitleStyle" parent="MaterialAlertDialog.Material3.Title.Text">
        <item name="android:textColor">#F8FAFC</item>
    </style>

    <style name="AlertDialogBodyStyle" parent="MaterialAlertDialog.Material3.Body.Text">
        <item name="android:textColor">#94A3B8</item>
    </style>
</resources>
