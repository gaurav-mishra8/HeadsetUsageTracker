<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark">

    <!-- Radial glow behind the card -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_permission_scrim" />

    <!-- Dimmed overlay for blur effect -->
    <View
        android:id="@+id/viewDimOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#B3000000"
        android:alpha="0" />

    <!-- Centered dialog card -->
    <LinearLayout
        android:id="@+id/cardDialog"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginHorizontal="24dp"
        android:orientation="vertical"
        android:background="@drawable/bg_permission_card"
        android:elevation="16dp"
        android:padding="28dp"
        android:alpha="0"
        android:translationY="60dp">

        <!-- Icon circle -->
        <FrameLayout
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_gravity="center_horizontal"
            android:background="@drawable/bg_permission_icon_circle">

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_shield"
                app:tint="@color/primary_light" />
        </FrameLayout>

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="24dp"
            android:text="Usage Access Required"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:textAlignment="center" />

        <!-- Subtitle -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="8dp"
            android:layout_marginHorizontal="8dp"
            android:text="To track which apps use your headphones, we need permission to view app usage data."
            android:textSize="14sp"
            android:textColor="@color/text_tertiary"
            android:textAlignment="center"
            android:lineSpacingMultiplier="1.3" />

        <!-- Divider -->
        <View
            android:layout_width="40dp"
            android:layout_height="2dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="20dp"
            android:background="@color/primary" />

        <!-- Bullet points -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="vertical"
            android:paddingHorizontal="4dp">

            <!-- Point 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_check_circle_small"
                    app:tint="@color/success"
                    android:layout_marginEnd="12dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="See which apps play audio through your headphones"
                    android:textSize="13.5sp"
                    android:textColor="@color/text_secondary"
                    android:lineSpacingMultiplier="1.2" />
            </LinearLayout>

            <!-- Point 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_check_circle_small"
                    app:tint="@color/success"
                    android:layout_marginEnd="12dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Track your daily and weekly listening habits"
                    android:textSize="13.5sp"
                    android:textColor="@color/text_secondary"
                    android:lineSpacingMultiplier="1.2" />
            </LinearLayout>

            <!-- Point 3 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_check_circle_small"
                    app:tint="@color/success"
                    android:layout_marginEnd="12dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Your data stays on-device — nothing is shared"
                    android:textSize="13.5sp"
                    android:textColor="@color/text_secondary"
                    android:lineSpacingMultiplier="1.2" />
            </LinearLayout>
        </LinearLayout>

        <!-- Grant permission button -->
        <FrameLayout
            android:id="@+id/btnGrantPermission"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="28dp"
            android:background="@drawable/bg_gradient_button"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?android:attr/selectableItemBackground">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_settings"
                    app:tint="@android:color/white"
                    android:layout_marginEnd="10dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Open Settings"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/white"
                    android:letterSpacing="0.03" />
            </LinearLayout>
        </FrameLayout>

        <!-- Privacy note -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="16dp"
            android:text="🔒 We only read app names — no personal data"
            android:textSize="12sp"
            android:textColor="@color/text_tertiary"
            android:textAlignment="center" />

    </LinearLayout>

</FrameLayout>

