<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@drawable/widget_background"
    android:padding="16dp">

    <ImageView
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:src="@drawable/ic_headphones"
        app:tint="@color/primary" />

    <TextView
        android:id="@+id/tvWidgetTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="0m"
        android:textSize="26sp"
        android:textColor="@android:color/white"
        android:fontFamily="sans-serif-medium" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Today"
        android:textSize="11sp"
        android:textColor="#99FFFFFF" />

    <TextView
        android:id="@+id/tvWidgetCurrentApp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text=""
        android:textSize="11sp"
        android:textColor="#CCFFFFFF"
        android:fontFamily="sans-serif-medium"
        android:maxLines="1"
        android:ellipsize="end" />

    <!-- Ear health budget bar — three pre-tinted variants, toggled by visibility -->
    <ProgressBar
        android:id="@+id/progressBudgetGreen"
        style="@android:style/Widget.ProgressBar.Horizontal"
        android:layout_width="match_parent"
        android:layout_height="5dp"
        android:layout_marginTop="8dp"
        android:layout_marginHorizontal="4dp"
        android:max="100"
        android:progress="0"
        android:progressDrawable="@drawable/widget_budget_green"
        android:visibility="visible" />
    <ProgressBar
        android:id="@+id/progressBudgetAmber"
        style="@android:style/Widget.ProgressBar.Horizontal"
        android:layout_width="match_parent"
        android:layout_height="5dp"
        android:layout_marginHorizontal="4dp"
        android:max="100"
        android:progress="0"
        android:progressDrawable="@drawable/widget_budget_amber"
        android:visibility="gone" />
    <ProgressBar
        android:id="@+id/progressBudgetRed"
        style="@android:style/Widget.ProgressBar.Horizontal"
        android:layout_width="match_parent"
        android:layout_height="5dp"
        android:layout_marginHorizontal="4dp"
        android:max="100"
        android:progress="0"
        android:progressDrawable="@drawable/widget_budget_red"
        android:visibility="gone" />

    <TextView
        android:id="@+id/tvWidgetBudget"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="Ear budget: 0%"
        android:textSize="9sp"
        android:textColor="#66FFFFFF" />

    <TextView
        android:id="@+id/tvWidgetStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="● Inactive"
        android:textSize="10sp"
        android:textColor="#66FFFFFF" />

    <TextView
        android:id="@+id/btnWidgetToggle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:paddingHorizontal="16dp"
        android:paddingVertical="6dp"
        android:background="@drawable/widget_btn_background"
        android:text="Start"
        android:textSize="12sp"
        android:textColor="@android:color/white"
        android:fontFamily="sans-serif-medium" />

</LinearLayout>
